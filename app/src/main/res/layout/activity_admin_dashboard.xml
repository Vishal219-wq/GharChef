<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/adminBottomNav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:weightSum="4">

        <LinearLayout android:id="@+id/navAdminDashboard" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_home" app:tint="#2E7D32"
                android:contentDescription="Dashboard"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dashboard" android:textColor="#2E7D32"
                android:textSize="10sp" android:textStyle="bold"
                android:fontFamily="@font/buenard_bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navAdminUsers" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_admin_users" app:tint="#9E9E9E"
                android:contentDescription="Users"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Users" android:textColor="#9E9E9E"
                android:textSize="10sp" android:fontFamily="@font/buenard"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navAdminItems" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_admin_menu" app:tint="#9E9E9E"
                android:contentDescription="Items"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Items" android:textColor="#9E9E9E"
                android:textSize="10sp" android:fontFamily="@font/buenard"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navAdminProfile" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_admin_profile" app:tint="#9E9E9E"
                android:contentDescription="Profile"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textColor="#9E9E9E"
                android:textSize="10sp" android:fontFamily="@font/buenard"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/adminBottomNav"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- GRADIENT HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="@drawable/bg_admin_header_gradient"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADMIN PANEL"
                        android:textColor="#AAFFFFFF"
                        android:textSize="11sp"
                        android:letterSpacing="0.15"
                        android:fontFamily="@font/anton"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GharChef"
                        android:textColor="@color/white"
                        android:textSize="30sp"
                        android:fontFamily="@font/adamina"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard Overview"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="@font/buenard"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_admin_shield"
                    app:tint="#33FFFFFF"
                    android:contentDescription="Admin Shield"/>
            </RelativeLayout>

            <!-- PROGRESS BAR -->
            <ProgressBar android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:indeterminate="true"
                style="?android:attr/progressBarStyleHorizontal"
                android:indeterminateTint="#2E7D32"
                android:visibility="gone"
                android:layout_marginBottom="0dp"/>

            <!-- STAT CARDS ROW 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Orders Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp"
                            android:src="@drawable/ic_admin_orders"
                            app:tint="#1565C0"
                            android:background="@drawable/bg_stat_icon_blue"
                            android:padding="6dp"
                            android:contentDescription="Orders"/>
                        <TextView android:id="@+id/tvTotalOrders"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#1A1A2E"
                            android:textSize="30sp"
                            android:fontFamily="@font/anton"
                            android:layout_marginTop="10dp"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Orders"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/buenard"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Users Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp"
                            android:src="@drawable/ic_admin_users"
                            app:tint="#6A1B9A"
                            android:background="@drawable/bg_stat_icon_purple"
                            android:padding="6dp"
                            android:contentDescription="Users"/>
                        <TextView android:id="@+id/tvTotalUsers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#1A1A2E"
                            android:textSize="30sp"
                            android:fontFamily="@font/anton"
                            android:layout_marginTop="10dp"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Registered Users"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/buenard"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- STAT CARDS ROW 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Menu Items Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp"
                            android:src="@drawable/ic_admin_menu"
                            app:tint="#E65100"
                            android:background="@drawable/bg_stat_icon_orange"
                            android:padding="6dp"
                            android:contentDescription="Menu"/>
                        <TextView android:id="@+id/tvTotalItems"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#1A1A2E"
                            android:textSize="30sp"
                            android:fontFamily="@font/anton"
                            android:layout_marginTop="10dp"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Menu Items"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:fontFamily="@font/buenard"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Revenue Card (gradient) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#00000000">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_revenue_card_gradient"
                        android:padding="18dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp"
                                android:src="@drawable/ic_admin_revenue"
                                app:tint="#FFFFFF"
                                android:background="@drawable/bg_stat_icon_white_alpha"
                                android:padding="6dp"
                                android:contentDescription="Revenue"/>
                            <TextView android:id="@+id/tvTotalRevenue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0"
                                android:textColor="@color/white"
                                android:textSize="22sp"
                                android:fontFamily="@font/anton"
                                android:layout_marginTop="10dp"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Revenue"
                                android:textColor="#CCFFFFFF"
                                android:textSize="12sp"
                                android:fontFamily="@font/buenard"/>
                        </LinearLayout>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- RECENT ORDERS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_admin_orders"
                            app:tint="#2E7D32"
                            android:contentDescription="Recent Orders"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recent Orders"
                            android:textColor="#1A1A2E"
                            android:textSize="16sp"
                            android:fontFamily="@font/adamina"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F0F0F0" android:layout_marginTop="12dp"
                        android:layout_marginBottom="10dp"/>

                    <TextView android:id="@+id/tvRecentOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="#555555"
                        android:textSize="13sp"
                        android:fontFamily="@font/buenard"
                        android:lineSpacingExtra="6dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- DEVELOPER TOOLS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FFFDE7"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_admin_tools"
                            app:tint="#F57F17"
                            android:contentDescription="Dev Tools"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Developer Tools"
                            android:textColor="#1A1A2E"
                            android:textSize="15sp"
                            android:fontFamily="@font/adamina"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Seed 14 sample menu items into Firestore. Run only ONCE on a fresh database."
                        android:textColor="#777777"
                        android:textSize="12sp"
                        android:fontFamily="@font/buenard"/>

                    <Button android:id="@+id/btnSeedData"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_button_amber"
                        android:stateListAnimator="@null"
                        android:text="Seed Sample Data"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:fontFamily="@font/buenard_bold"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>